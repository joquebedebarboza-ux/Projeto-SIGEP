-- =====================================
-- VISUALIZAR TUDO (BÁSICO)
-- =====================================
SELECT * FROM Cargos;
SELECT * FROM Funcionarios;
SELECT * FROM Clientes;
SELECT * FROM Mesas;
SELECT * FROM Produtos;
SELECT * FROM Insumos;
SELECT * FROM Estoque;
SELECT * FROM Pedidos;
SELECT * FROM Itens_Pedido;
SELECT * FROM Pagamentos;
SELECT * FROM Entregas;
SELECT * FROM Reservas;

-- =====================================
-- PEDIDO COMPLETO (COM ITENS E CLIENTE)
-- =====================================
SELECT 
    p.id_pedido,
    c.nome AS cliente,
    m.numero_mesa,
    p.tipo,
    p.origem,
    p.status,
    pr.nome_produto,
    i.quantidade,
    i.observacao
FROM Pedidos p
JOIN Clientes c ON p.id_cliente = c.id_cliente
LEFT JOIN Mesas m ON p.id_mesa = m.id_mesa
JOIN Itens_Pedido i ON p.id_pedido = i.id_pedido
JOIN Produtos pr ON i.id_produto = pr.id_produto
ORDER BY p.id_pedido;

-- =====================================
-- PEDIDOS COM PAGAMENTO
-- =====================================
SELECT 
    p.id_pedido,
    c.nome AS cliente,
    p.tipo,
    p.status,
    pg.tipo_pagamento,
    pg.valor,
    pg.status AS status_pagamento
FROM Pedidos p
JOIN Clientes c ON p.id_cliente = c.id_cliente
JOIN Pagamentos pg ON p.id_pedido = pg.id_pedido;

-- =====================================
-- ENTREGAS COM CLIENTE
-- =====================================
SELECT 
    e.id_entrega,
    p.id_pedido,
    c.nome AS cliente,
    e.endereco_entrega,
    e.status
FROM Entregas e
JOIN Pedidos p ON e.id_pedido = p.id_pedido
JOIN Clientes c ON p.id_cliente = c.id_cliente;

-- =====================================
-- RESERVAS COM CLIENTE E MESA
-- =====================================
SELECT 
    r.id_reserva,
    c.nome AS cliente,
    m.numero_mesa,
    r.data_reserva,
    r.hora_reserva,
    r.status
FROM Reservas r
JOIN Clientes c ON r.id_cliente = c.id_cliente
JOIN Mesas m ON r.id_mesa = m.id_mesa;

-- =====================================
-- ESTOQUE COM NOME DO INSUMO
-- =====================================
SELECT 
    i.nome_insumo,
    e.quantidade,
    e.data_entrada
FROM Estoque e
JOIN Insumos i ON e.id_insumo = i.id_insumo;

-- =====================================
-- FUNCIONÁRIOS COM CARGO
-- =====================================
SELECT 
    f.nome,
    f.usuario,
    c.nome_cargo,
    f.turno
FROM Funcionarios f
JOIN Cargos c ON f.id_cargo = c.id_cargo;
