CREATE DATABASE sigep_pizzaria;
USE sigep_pizzaria;

-- =====================================
-- ADMINISTRATIVO
-- =====================================

CREATE TABLE Cargos (
    id_cargo INT AUTO_INCREMENT PRIMARY KEY COMMENT 'Identificador do cargo',
    nome_cargo VARCHAR(50) NOT NULL COMMENT 'Nome do cargo (Gerente, Garçom, etc.)'
) COMMENT='Tabela de cargos dos funcionários';

CREATE TABLE Funcionarios (
    id_funcionario INT AUTO_INCREMENT PRIMARY KEY COMMENT 'Identificador do funcionário',
    nome VARCHAR(100) NOT NULL COMMENT 'Nome completo do funcionário',
    usuario VARCHAR(50) UNIQUE COMMENT 'Login do sistema',
    senha VARCHAR(255) COMMENT 'Senha de acesso',
    id_cargo INT COMMENT 'Cargo do funcionário',
    turno ENUM('Manhã','Tarde','Noite') COMMENT 'Turno de trabalho',
    FOREIGN KEY (id_cargo) REFERENCES Cargos(id_cargo)
) COMMENT='Tabela de funcionários da pizzaria';

-- =====================================
-- DISPOSITIVOS
-- =====================================

CREATE TABLE Dispositivos (
    id_dispositivo INT AUTO_INCREMENT PRIMARY KEY COMMENT 'Identificador do dispositivo',
    tipo ENUM(
        'TV Cozinha',
        'Painel Expedição',
        'TV Expedição',
        'Computador',
        'Maquininha Cartão',
        'Celular',
        'Totem'
    ) COMMENT 'Tipo do dispositivo utilizado no sistema',
    localizacao VARCHAR(100) COMMENT 'Local onde o dispositivo está',
    status ENUM('Ativo','Inativo') DEFAULT 'Ativo' COMMENT 'Status do dispositivo'
) COMMENT='Dispositivos utilizados no funcionamento da pizzaria';

-- =====================================
-- CLIENTES
-- =====================================

CREATE TABLE Clientes (
    id_cliente INT AUTO_INCREMENT PRIMARY KEY COMMENT 'Identificador do cliente',
    nome VARCHAR(100) COMMENT 'Nome do cliente',
    telefone VARCHAR(20) COMMENT 'Telefone para contato',
    email VARCHAR(100) COMMENT 'Email do cliente',
    endereco VARCHAR(200) COMMENT 'Endereço para entrega'
) COMMENT='Cadastro de clientes';

-- =====================================
-- MESAS
-- =====================================

CREATE TABLE Mesas (
    id_mesa INT AUTO_INCREMENT PRIMARY KEY COMMENT 'Identificador da mesa',
    numero_mesa INT COMMENT 'Número físico da mesa',
    andar ENUM('1º','2º') COMMENT 'Andar da pizzaria',
    status ENUM('Disponível','Indisponível','Reservada') COMMENT 'Situação da mesa'
) COMMENT='Mesas físicas da pizzaria';

-- =====================================
-- RESERVAS
-- =====================================

CREATE TABLE Reservas (
    id_reserva INT AUTO_INCREMENT PRIMARY KEY COMMENT 'Identificador da reserva',
    id_cliente INT COMMENT 'Cliente que fez a reserva',
    id_mesa INT COMMENT 'Mesa reservada',
    data_reserva DATE COMMENT 'Data da reserva',
    hora_reserva TIME COMMENT 'Horário da reserva',
    telefone_reserva VARCHAR(20) COMMENT 'Telefone de confirmação',
    taxa_reserva DECIMAL(10,2) COMMENT 'Valor da taxa de reserva',
    status ENUM('Ativa','Cancelada','Reagendada') COMMENT 'Status da reserva',
    observacao VARCHAR(200) COMMENT 'Observações da reserva',
    FOREIGN KEY (id_cliente) REFERENCES Clientes(id_cliente),
    FOREIGN KEY (id_mesa) REFERENCES Mesas(id_mesa)
) COMMENT='Controle de reservas de mesas';

-- =====================================
-- PRODUTOS
-- =====================================

CREATE TABLE Produtos (
    id_produto INT AUTO_INCREMENT PRIMARY KEY COMMENT 'Identificador do produto',
    nome_produto VARCHAR(100) COMMENT 'Nome do produto',
    categoria VARCHAR(50) COMMENT 'Categoria (Pizza, Bebida, etc.)',
    tamanho ENUM('Broto','Média','Grande','Família') COMMENT 'Tamanho do produto',
    preco DECIMAL(10,2) COMMENT 'Preço do produto'
) COMMENT='Cardápio da pizzaria';

-- =====================================
-- INSUMOS / ESTOQUE
-- =====================================

CREATE TABLE Insumos (
    id_insumo INT AUTO_INCREMENT PRIMARY KEY COMMENT 'Identificador do insumo',
    nome_insumo VARCHAR(100) COMMENT 'Nome do insumo',
    unidade ENUM('ml','L','g','kg','unidade') COMMENT 'Unidade de medida'
) COMMENT='Matéria-prima utilizada na produção';

CREATE TABLE Estoque (
    id_estoque INT AUTO_INCREMENT PRIMARY KEY COMMENT 'Identificador do estoque',
    id_insumo INT COMMENT 'Insumo armazenado',
    quantidade DECIMAL(10,2) COMMENT 'Quantidade disponível',
    data_entrada DATE COMMENT 'Data de entrada no estoque',
    data_saida DATE COMMENT 'Data de saída do estoque',
    FOREIGN KEY (id_insumo) REFERENCES Insumos(id_insumo)
) COMMENT='Controle de estoque de insumos';

-- =====================================
-- PEDIDOS
-- =====================================

CREATE TABLE Pedidos (
    id_pedido INT AUTO_INCREMENT PRIMARY KEY COMMENT 'Identificador do pedido',
    id_cliente INT COMMENT 'Cliente que realizou o pedido',
    id_mesa INT NULL COMMENT 'Mesa (se presencial)',
    tipo ENUM('Presencial','Delivery') COMMENT 'Tipo do pedido',
    
    origem ENUM(
        'WhatsApp',
        'iFood',
        'Rappi',
        'Uber Eats',
        'Site',
        'Balcão',
        'Totem'
    ) COMMENT 'Origem do pedido',
    
    status ENUM(
        'Pedido recebido',
        'Em fila',
        'Em preparo',
        'No forno',
        'Finalizado',
        'Pronto',
        'Saiu para entrega',
        'Servindo mesa'
    ) COMMENT 'Status do pedido',
    
    data_hora DATETIME DEFAULT CURRENT_TIMESTAMP COMMENT 'Data e hora do pedido',
    
    FOREIGN KEY (id_cliente) REFERENCES Clientes(id_cliente),
    FOREIGN KEY (id_mesa) REFERENCES Mesas(id_mesa)
) COMMENT='Pedidos realizados na pizzaria';

-- =====================================
-- ITENS DO PEDIDO
-- =====================================

CREATE TABLE Itens_Pedido (
    id_item INT AUTO_INCREMENT PRIMARY KEY COMMENT 'Item do pedido',
    id_pedido INT COMMENT 'Pedido relacionado',
    id_produto INT COMMENT 'Produto do pedido',
    quantidade INT COMMENT 'Quantidade do item',
    observacao VARCHAR(200) COMMENT 'Observações do cliente',
    FOREIGN KEY (id_pedido) REFERENCES Pedidos(id_pedido),
    FOREIGN KEY (id_produto) REFERENCES Produtos(id_produto)
) COMMENT='Itens que compõem cada pedido';

-- =====================================
-- PAGAMENTOS
-- =====================================

CREATE TABLE Pagamentos (
    id_pagamento INT AUTO_INCREMENT PRIMARY KEY COMMENT 'Identificador do pagamento',
    id_pedido INT COMMENT 'Pedido pago',
    tipo_pagamento ENUM(
        'Dinheiro',
        'Cartão Crédito',
        'Cartão Débito',
        'Pix',
        'Carteira Digital',
        'iFood',
        'Rappi',
        'Uber Eats'
    ) COMMENT 'Forma de pagamento',
    valor DECIMAL(10,2) COMMENT 'Valor pago',
    status ENUM('Pago','Pendente') COMMENT 'Situação do pagamento',
    FOREIGN KEY (id_pedido) REFERENCES Pedidos(id_pedido)
) COMMENT='Pagamentos dos pedidos';

-- =====================================
-- ENTREGAS
-- =====================================

CREATE TABLE Entregas (
    id_entrega INT AUTO_INCREMENT PRIMARY KEY COMMENT 'Identificador da entrega',
    id_pedido INT COMMENT 'Pedido entregue',
    endereco_entrega VARCHAR(200) COMMENT 'Endereço da entrega',
    status ENUM(
        'Pedido recebido',
        'Em preparo',
        'Saiu para entrega',
        'Entregue'
    ) COMMENT 'Status da entrega',
    FOREIGN KEY (id_pedido) REFERENCES Pedidos(id_pedido)
) COMMENT='Controle de entregas';

